# ====================================================================
# Configuración Local de Entorno para Docker Compose (.env)
# ====================================================================
# Copia este archivo como '.env' en la raíz antes de levantar Docker:
# cp .env.example .env

# Contraseña de la base de datos MySQL local
DB_PASSWORD=mysql

# Clave secreta para la generación de tokens JWT en backend
JWT_SECRET=genera-una-clave-segura-de-al-menos-32-bytes-para-produccion

# Proveedor de pasarela de pagos (MOCK, STRIPE)
PAYMENT_GATEWAY_PROVIDER=MOCK
STRIPE_SECRET_KEY=sk_test_51P1dummykey

# Configuración de Servidor de Correo (Gmail)
# Activa el envío de alertas reales configurando estas variables de entorno en tu .env local:
SPRING_MAIL_USERNAME=tu_correo_gmail@gmail.com
SPRING_MAIL_PASSWORD=tu_clave_de_aplicacion_gmail_de_16_caracteres
