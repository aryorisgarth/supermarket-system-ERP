# ====================================================================
# .gitignore Global - Sistema Supermercado Supernova
# ====================================================================

# --------------------------------------------------------------------
# 1. Archivos de Sistema Operativo y Editores/IDEs
# --------------------------------------------------------------------
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# VSCode
.vscode/
!.vscode/extensions.json
*.code-workspace
.history/

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# Eclipse / NetBeans
.metadata/
.project
.classpath
.settings/
*.launch
nbproject/private/
build/
dist/

# Herramientas Auxiliares de IA o Scratch
.aider*
/scratch/
backups/

# --------------------------------------------------------------------
# 2. Node.js & React (Frontend)
# --------------------------------------------------------------------
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Compilaciones
/03-FRONTEND/dist/
/03-FRONTEND/build/

# Archivos de entorno sensibles
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
/03-FRONTEND/.env

# --------------------------------------------------------------------
# 3. Java & Maven (Backend)
# --------------------------------------------------------------------
*.class
*.bluej

# Maven build directories
target/
**/target/

# Maven files
pom.xml.tag
pom.xml.releaseBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# --------------------------------------------------------------------
# 4. Python (Venv)
# --------------------------------------------------------------------
venv/
.venv/
env/
ENV/
*.pyc
__pycache__/
*.pyo
*.pyd

# --------------------------------------------------------------------
# 5. Docker & Base de Datos
# --------------------------------------------------------------------
# Evitar subir carpetas de volumen local de base de datos
docker/db_data/
docker/mysql/data/
**/mysql/data/
mysql_data/
data/mysql/

# --------------------------------------------------------------------
# 6. Logs, Temporales y Backups
# --------------------------------------------------------------------
*.log
logs/
**/logs/
*.bak
*.sql.gz
*.db
*.sqlite
