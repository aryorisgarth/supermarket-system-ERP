# Base de datos
DB_URL=jdbc:mysql://localhost:3306/supermarket_system
DB_USERNAME=root
DB_PASSWORD=mysql
DDL_AUTO=validate

# Servidor
PORT=8081
SPRING_PROFILES_ACTIVE=

# Seguridad (obligatorio en producción: SPRING_PROFILES_ACTIVE=prod)
JWT_SECRET=genera-una-clave-segura-de-al-menos-32-bytes
JWT_EXPIRATION_MS=86400000

# CORS (orígenes separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Datos iniciales (false en producción)
SEED_ENABLED=true

# Usuarios demo (solo si la BD está vacía y SEED_ENABLED=true):
# admin@supermarket.local / Admin12345!  -> ADMIN_INGENIERO
# cajero@supermarket.local / Cajero12345! -> CAJERO

# Facturación electrónica y pagos (GT=Guatemala SAT-FEL, CO=Colombia DIAN)
BILLING_COUNTRY=GT
ELECTRONIC_INVOICE_ENABLED=true
ISSUER_TAX_ID=1234567-8
PAYMENT_GATEWAY_ENABLED=true
PAYMENT_GATEWAY_PROVIDER=MOCK
PAYMENT_CURRENCY=GTQ
